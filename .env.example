# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Groq API key (free at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── LLM MODEL ─────────────────────────────────────────────────────────────────
# Recommended: llama-3.3-70b-versatile (best quality, 100k tokens/day free)
# Fallback:    llama-3.1-8b-instant    (faster, separate rate limit)
LLM_MODEL=llama-3.3-70b-versatile

# ── EMBEDDING MODEL ───────────────────────────────────────────────────────────
# Runs locally — no API key needed. ~80MB download on first run.
# Upgrade option: all-mpnet-base-v2 (better quality, ~420MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── STORAGE ───────────────────────────────────────────────────────────────────
CHROMA_DIR=data/chroma_db
